# Google OAuth 2.0 client ID (from Google Cloud Console → Credentials)
# This is safe to expose in the browser — it identifies your app, not a secret.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Google Sheet ID (the long string in your Sheet URL between /d/ and /edit)
# e.g. https://docs.google.com/spreadsheets/d/THIS_PART/edit
VITE_SHEET_ID=your-sheet-id

# OpenAI API key — server-side only, never exposed to the browser.
# Set this in Vercel project settings (Environment Variables), not in .env.local.
OPENAI_API_KEY=sk-...
